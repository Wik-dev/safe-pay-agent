{
  "templates": {
    "ton_escrow": {
      "description": "Deploy a TON escrow contract and deposit funds. Creates a new SafePayment contract with specified recipient and condition, then deposits the specified amount.",
      "persistent": false,
      "docker_image": "ton-worker",
      "command_template": "node /app/dist/ton_escrow.js",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "recipient": {"type": "string", "description": "TON address of the payment recipient"},
          "amount": {"type": "string", "description": "Amount in TON to deposit (e.g. '0.5')"},
          "condition": {"type": "string", "description": "Human-readable condition for releasing the payment"}
        },
        "required": ["recipient", "amount", "condition"]
      },
      "approval_tier": "human-confirm",
      "timeout": 120,
      "rate_limit": 3,
      "secret_refs": ["TON_MNEMONIC", "TON_API_ENDPOINT", "TON_API_KEY"],
      "network_policy": {
        "egress_whitelist": ["testnet.toncenter.com", "toncenter.com"]
      },
      "keywords": ["send", "pay", "transfer", "escrow", "deploy"],
      "display": {
        "title": "Deploy Escrow Contract",
        "result_title": "Escrow Deployed",
        "param_labels": { "recipient": "Recipient", "amount": "Amount (TON)", "condition": "Condition" },
        "result_labels": { "contract_address": "Contract", "recipient": "Recipient", "amount": "Amount (TON)", "condition": "Condition", "status": "Status" },
        "context_fields": ["contract_address", "amount", "recipient", "condition"],
        "context_status_field": "status",
        "context_active_value": "deployed"
      }
    },
    "ton_release": {
      "description": "Release escrowed funds to the recipient. Sends the Release message to an existing SafePayment contract, transferring all funds to the designated recipient.",
      "persistent": false,
      "docker_image": "ton-worker",
      "command_template": "node /app/dist/ton_release.js",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "contract_address": {"type": "string", "description": "Address of the deployed SafePayment contract"}
        },
        "required": ["contract_address"]
      },
      "approval_tier": "human-confirm",
      "timeout": 120,
      "rate_limit": 5,
      "secret_refs": ["TON_MNEMONIC", "TON_API_ENDPOINT", "TON_API_KEY"],
      "network_policy": {
        "egress_whitelist": ["testnet.toncenter.com", "toncenter.com"]
      },
      "keywords": ["release", "confirm", "approve payment"],
      "display": {
        "title": "Release Escrow Funds",
        "result_title": "Funds Released",
        "param_labels": { "contract_address": "Contract" },
        "result_labels": { "contract_address": "Contract", "recipient": "Recipient", "status": "Status" },
        "context_fields": ["contract_address", "recipient"],
        "context_status_field": "status",
        "context_active_value": "released"
      }
    },
    "ton_refund": {
      "description": "Refund escrowed funds back to the owner. Sends the Refund message to an existing SafePayment contract, returning all funds to the contract owner.",
      "persistent": false,
      "docker_image": "ton-worker",
      "command_template": "node /app/dist/ton_refund.js",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "contract_address": {"type": "string", "description": "Address of the deployed SafePayment contract"}
        },
        "required": ["contract_address"]
      },
      "approval_tier": "human-confirm",
      "timeout": 120,
      "rate_limit": 5,
      "secret_refs": ["TON_MNEMONIC", "TON_API_ENDPOINT", "TON_API_KEY"],
      "network_policy": {
        "egress_whitelist": ["testnet.toncenter.com", "toncenter.com"]
      },
      "keywords": ["refund", "cancel", "return"],
      "display": {
        "title": "Refund Escrow",
        "result_title": "Funds Refunded",
        "param_labels": { "contract_address": "Contract" },
        "result_labels": { "contract_address": "Contract", "owner": "Owner", "status": "Status" },
        "context_fields": ["contract_address", "owner"],
        "context_status_field": "status",
        "context_active_value": "refunded"
      }
    },
    "ton_balance": {
      "description": "Check the TON balance of an address. If no address is provided, checks the bot's own wallet balance.",
      "persistent": false,
      "docker_image": "ton-worker",
      "command_template": "node /app/dist/ton_balance.js",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "address": {"type": "string", "description": "TON address to check balance for. Omit to check the bot's own wallet."}
        },
        "required": []
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 10,
      "secret_refs": ["TON_API_ENDPOINT", "TON_API_KEY"],
      "network_policy": {
        "egress_whitelist": ["testnet.toncenter.com", "toncenter.com"]
      },
      "keywords": ["balance", "check"],
      "display": {
        "title": "Check Balance",
        "result_title": "Balance",
        "param_labels": { "address": "Address" },
        "result_labels": { "address": "Address", "balance": "Balance (TON)", "state": "State", "status": "Status" },
        "context_fields": ["address", "balance"],
        "context_status_field": "status",
        "context_active_value": "checked"
      }
    }
  },
  "keywords_global": ["contract", "deny"],
  "keyword_patterns": ["\\d+(\\.\\d+)?\\s*(ton|TON)", "(?:EQ|UQ)[A-Za-z0-9_-]{46,48}"],
  "images": {
    "ton-worker": "safe-pay-ton-worker:latest"
  }
}
